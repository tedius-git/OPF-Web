---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className, hover = false } = Astro.props;
---

<div class:list={['tarjeta-base', { 'motion-hover': hover }, className]}>
  <slot /> 
  </div>

<style>

  .tarjeta-base {
    background-color: #ffffff;
    border: 1px solid var(--gris);
    border-radius: 12px;
    padding: 2rem;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    transition: all 0.1s ease;
    position: relative;
  }

  .tarjeta-base {
    height: auto;
    width: 100%;
    box-sizing: border-box;
  }
</style>