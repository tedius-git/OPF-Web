---
interface Props {
  href: string;
  class?: string;
  target?: string;
}

const { href, class: className, target } = Astro.props;
---

<a href={href} target={target} class:list={["boton-base", className]}>
  <slot />
</a>

<style>
  .boton-base {
    display: inline-block;
    background: var(--naranja);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    transition: 0.3s;
    text-align: center;
    border: none;
  }

  .boton-base:hover {
    background: var(--dorado);
    transform: translateY(-3px);
    box-shadow: 0 4px 12px rgba(200, 150, 12, 0.3);
  }
</style>
