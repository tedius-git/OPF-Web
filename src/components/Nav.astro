---
import { Image } from "astro:assets";
import logo from "../assets/olilogo.png";
const navLinks = [
  { link: "/convocatoria", label: "Convocatoria" },
  { link: "/recursos", label: "Recursos" },
  { link: "/resultados", label: "Resultados" },
  { link: "/nosotros", label: "Nosotros" },
];
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<div class="bar"></div>
<nav aria-label="Navegación principal">
  <a
    href="/"
    class:list={[{ active: currentPath === "/" }]}
    aria-label="Olimpiada Potosina de Física"
  >
    <Image src={logo} alt="OPF" loading="eager" />
  </a>

  <!-- Botón hamburguesa (solo mobile) -->
  <button id="menu-toggle" aria-label="Abrir menú" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <div id="nav-links">
    {
      navLinks.map(({ link, label }) => (
        <a href={link} class:list={[{ active: currentPath === link }]}>
          {label}
        </a>
      ))
    }
  </div>
</nav>

<script>
  import { animate } from "motion";

  const activeLink = document.querySelector("a.active");
  if (activeLink) {
    animate(activeLink, { scaleY: [0, 1.1, 1] }, { duration: 0.5 });
  }

  // Hamburguesa
  const toggle = document.getElementById("menu-toggle");
  const navLinks = document.getElementById("nav-links");

  toggle?.addEventListener("click", () => {
    const isOpen = navLinks?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(isOpen));
  });
</script>

<style>
  nav {
    padding: 0.5rem 5rem 0rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    height: 70px;
    position: relative;
  }

  a {
    position: relative;
    text-decoration: none;
    font-size: 1.3em;
    margin-left: 1em;
    letter-spacing: 0.05em;
    color: var(--negro);
    border-radius: 10px;
    display: flex;
    align-items: center;
  }

  a.active {
    transform-origin: top center;
    margin-top: -16px;
    z-index: 101;
    padding: 0 0.6rem;
    background:
      linear-gradient(var(--crema), var(--crema)) padding-box,
      linear-gradient(var(--naranja), var(--naranja)) border-box;
    border: 8px solid transparent;
    border-top: none;
    border-radius: 0 0 10px 10px;
  }

  img {
    width: 50px;
    height: auto;
  }

  .bar {
    position: sticky;
    top: 0;
    height: 8px;
    z-index: 100;
    background: var(--naranja);
  }

  /* Hamburguesa — oculto en desktop */
  #menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 200;
  }

  #menu-toggle span {
    display: block;
    width: 26px;
    height: 3px;
    background: var(--negro);
    border-radius: 2px;
    transition: 0.3s;
  }

  /* Links en desktop: fila normal */
  #nav-links {
    display: flex;
    align-items: stretch;
    gap: 0.5rem;
  }

  @media (max-width: 600px) {
    nav {
      padding: 0.5em 0rem 0rem 1rem;
      flex-wrap: wrap;
      height: auto;
      min-height: 60px;
      align-items: center;
    }

    img {
      width: 40px;
    }

    a.active {
      margin-top: -26px;
      padding: 20px 0.6rem 8px;
    }

    #menu-toggle {
      display: flex;
      padding-right: 1.5em;
    }

    /* Menú desplegable */
    #nav-links {
      display: none;
      flex-direction: column;
      width: 100%;
      background: var(--crema);
      margin-top: 8px;
      gap: 0;
    }

    #nav-links.open {
      display: flex;
    }

    #nav-links a {
      font-size: 1em;
      padding: 0.5rem;
      margin: 0;
    }

    /* En mobile el tab activo se muestra como fondo simple */
    #nav-links a.active {
      border: solid 4px var(--naranja);
      border-right: none;
      border-radius: 8px 0px 0px 8px;
    }
  }
</style>
