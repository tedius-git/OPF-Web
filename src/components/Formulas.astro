---
const FORMULAS = [
  { text: "E = mc²"          },
  { text: "F = ma"           },
  { text: "∇ × B = μ₀J"     },
  { text: "PV = nRT"         },
  { text: "λ = h/p"          },
  { text: "ΔS ≥ 0"           },
  { text: "∇·E = ρ/ε₀"      },
  { text: "Ĥψ = Eψ"          },
  { text: "v² = v₀² + 2aΔx" },
  { text: "F = −kx"          },
];
---

<div class="formulas-bg" aria-hidden="true">
  {FORMULAS.map(({ text }) => (
    <span class="formula-item">{text}</span>
  ))}
</div>

<style>
  .formulas-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }

  .formula-item {
    position: absolute;
    top: 0;
    left: 0;
    font-style: italic;
    opacity: 0.36;
    color: var(--negro, #1A1A1A);
    white-space: nowrap;
    user-select: none;
    will-change: transform;
  }
</style>

<script>
  const STORAGE_KEY = "opf-formulas-v3";
  const SAVE_INTERVAL = 2000;

  interface FormulaState {
    x: number;
    y: number;
    vx: number;
    vy: number;
    size: number;
  }

  const spans = Array.from(
    document.querySelectorAll<HTMLElement>(".formula-item")
  );

  if (spans.length === 0) throw new Error("No formula spans found");

  function loadState(): FormulaState[] | null {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw) as FormulaState[];
      if (!Array.isArray(parsed) || parsed.length !== spans.length) return null;
      return parsed;
    } catch {
      return null;
    }
  }

  function generateState(W: number, H: number): FormulaState[] {
    const speed = 30;
    return spans.map(() => ({
      x:    Math.random() * W * 0.9,
      y:    Math.random() * H * 0.9,
      vx:   (Math.random() - 0.5) * speed * 2,
      vy:   (Math.random() - 0.5) * speed * 2,
      size: parseFloat((0.7 + Math.random() * 1.4).toFixed(2)),
    }));
  }

  function saveState(state: FormulaState[]) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    } catch {}
  }

  // Viewport cacheado — solo se actualiza en resize
  let W = window.innerWidth;
  let H = window.innerHeight;

  let state = loadState() ?? generateState(W, H);

  spans.forEach((span, i) => {
    span.style.fontSize = `${state[i].size}rem`;
  });

  // Reescalar posiciones al nuevo viewport
  function onResize() {
    const newW = window.innerWidth;
    const newH = window.innerHeight;
    const scaleX = newW / W;
    const scaleY = newH / H;

    for (const s of state) {
      s.x  *= scaleX;
      s.y  *= scaleY;
      s.vx *= scaleX;
      s.vy *= scaleY;
    }

    W = newW;
    H = newH;
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(onResize, 150);
  });

  let lastTime: number | null = null;
  let lastSave = performance.now();

  function tick(now: number) {
    if (lastTime === null) { lastTime = now; }
    const dt = Math.min((now - lastTime) / 1000, 0.1);
    lastTime = now;

    for (let i = 0; i < state.length; i++) {
      const s = state[i];

      s.x += s.vx * dt;
      s.y += s.vy * dt;

      const maxX = W - spans[i].offsetWidth;
      const maxY = H - spans[i].offsetHeight;

      if (s.x < 0)    { s.x = 0;    s.vx =  Math.abs(s.vx); }
      if (s.x > maxX) { s.x = maxX; s.vx = -Math.abs(s.vx); }
      if (s.y < 0)    { s.y = 0;    s.vy =  Math.abs(s.vy); }
      if (s.y > maxY) { s.y = maxY; s.vy = -Math.abs(s.vy); }

      spans[i].style.transform = `translate(${s.x}px, ${s.y}px)`;
    }

    if (now - lastSave > SAVE_INTERVAL) {
      saveState(state);
      lastSave = now;
    }

    rafId = requestAnimationFrame(tick);
  }

  let rafId = requestAnimationFrame(tick);

  window.addEventListener("pagehide", () => saveState(state));
  document.addEventListener("visibilitychange", () => {
    if (document.visibilityState === "hidden") saveState(state);
  });
</script>
