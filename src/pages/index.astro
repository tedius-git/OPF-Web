---
import Layout from "../layouts/Layout.astro";
import Etiqueta from "../components/Etiqueta.astro";
import Boton from "../components/Boton.astro";
import Tarjeta from "../components/Tarjeta.astro";
import Seccion from "../components/Seccion.astro";
---

<Layout formulas={false}>
  <section class:list={["hero", "motion-fadein"]}>
    <h1>
      <span>Olimpiada Potosina</span><br />
      <span class="gradiente-naranja">de Física</span>
    </h1>
    <p class="hero-subtitulo">
      Descubre, comprende y desafía las leyes del universo. Únete a la
      delegación que representará a San Luis Potosí.
    </p>
    <div class="hero-acciones">
      <Etiqueta href="/convocatoria">Convocatoria Abierta</Etiqueta>
    </div>
  </section>

  <Tarjeta class="motion-fadein">
    <h2>¿Qué es la OPF?</h2>
    <p>
      La Olimpiada Potosina de Física es un certamen anual dirigido a
      estudiantes de nivel medio superior en San Luis Potosí. Nuestro objetivo
      es promover el estudio de la física, identificar talentos jóvenes y
      seleccionar a los mejores perfiles para conformar la delegación estatal
      que participará en la Olimpiada Nacional.
    </p>
  </Tarjeta>

  <section class="fechas motion-fadein">
    <div class="contenedor">
      <h2 class="centrado">Fechas Importantes</h2>
      <div class="grid-fechas">
        <Tarjeta>
          <h3>Cierre de Inscripciones</h3>
          <p class="fecha-texto">[Pendiente]</p>
        </Tarjeta>

        <Tarjeta titulo="¡Proximamente!" acento="naranja" alineado="center">
          <h3>Examen Selectivo Estatal</h3>
          <p class="fecha-texto principal">02 / 05 / 2026</p>
          <p class="hora-texto">10:00 a.m.</p>
        </Tarjeta>

        <Tarjeta>
          <h3>Inicio de Entrenamientos</h3>
          <p class="fecha-texto">[Pendiente]</p>
        </Tarjeta>
      </div>
    </div>
  </section>

  <Seccion titulo="Prepárate para el reto">
    <div class="contenedor flex-recursos">
      <div class="recursos-texto">
        <p>
          No importa si es tu primera vez participando. Ponemos a tu disposición
          material de estudio, el temario oficial y exámenes de años anteriores
          para que llegues con la mejor preparación.
        </p>
      </div>
      <div class="recursos-enlaces">
        <Boton href="/recursos/temario">Ver Temario Oficial &rarr;</Boton>
        <Boton href="/recursos/material">Exámenes Anteriores &rarr;</Boton>
      </div>
    </div>
  </Seccion>
</Layout>

<script>
  import { animate, inView } from "motion";

  inView(".motion-fadein", (element) => {
    animate(
      element,
      { opacity: [0, 1], y: [20, 0] },
      { duration: 0.6, easing: [0.22, 1, 0.36, 1] },
    );
  });
</script>
<style>
  h2 {
    color: var(--azul-uaslp);
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .centrado {
    text-align: center;
  }

  .gradiente-naranja {
    background: linear-gradient(to right, var(--naranja), var(--dorado));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* === Hero === */
  section.hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    min-height: 40vh;
  }
  section.hero h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    width: min(100%, 900px);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .hero-subtitulo {
    font-size: 1.2rem;
    max-width: 600px;
    line-height: 1.5;
    margin-bottom: 2rem;
  }
  .hero-acciones {
    margin-top: 1rem;
  }

  /* === Fechas === */
  section.fechas {
    padding: 5rem 0;
  }
  .grid-fechas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  .fecha-texto {
    font-size: 1.1rem;
    font-weight: 600;
  }
  .fecha-texto.principal {
    font-size: 1.4rem;
    color: var(--dorado);
  }
  .hora-texto {
    color: var(--verde);
    font-weight: bold;
    margin-top: 0.3rem;
  }

  /* === Recursos === */
  .flex-recursos {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .recursos-texto {
    flex: 1 1 400px;
  }
  .recursos-enlaces {
    flex: 1 1 300px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    section.hero {
      padding: 3rem 1rem;
    }
  }
</style>
