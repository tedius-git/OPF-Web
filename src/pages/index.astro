---
import Layout from '../layouts/Layout.astro';
import Etiqueta from '../components/Etiqueta.astro';
---

<Layout formulas={false}>
  <section class:list={["hero", "motion-fadein"]}>
    <h1>
      <span>Olimpiada Potosina</span><br>
      <span class="gradiente-naranja">de Física</span>
    </h1>
    <p class="hero-subtitulo">
      Descubre, comprende y desafía las leyes del universo. Únete a la delegación que representará a San Luis Potosí.
    </p>
    <div class="hero-acciones">
      <Etiqueta href="/convocatoria">
        Convocatoria Abierta
      </Etiqueta>
    </div>
  </section>

  <section class="info-general motion-fadein">
    <div class="contenedor">
      <h2>¿Qué es la OPF?</h2>
      <p>
        La Olimpiada Potosina de Física es un certamen anual dirigido a estudiantes de nivel medio superior en San Luis Potosí. Nuestro objetivo es promover el estudio de la física, identificar talentos jóvenes y seleccionar a los mejores perfiles para conformar la delegación estatal que participará en la Olimpiada Nacional.
      </p>
    </div>
  </section>

  <section class="fechas motion-fadein">
    <div class="contenedor">
      <h2 class="centrado">Fechas Importantes</h2>
      <div class="grid-fechas">
        
        <div class="tarjeta-fecha">
          <h3>Cierre de Inscripciones</h3>
          <p class="fecha-texto">[Pendiente]</p>
        </div>


        <! -- Ejemplo de fecha, pegar las etiquetas faltantes a las otras si quieren cfff -->
        <div class="tarjeta-fecha destacada motion-hover">
          <div class="etiqueta-alerta">¡Próximamente!</div>
          <h3>Examen Selectivo Estatal</h3>
          <p class="fecha-texto principal">02 / 05 / 2026</p>
          <p class="hora-texto">10:00 a.m.</p>
        </div>

        <div class="tarjeta-fecha">
          <h3>Inicio de Entrenamientos</h3>
          <p class="fecha-texto">[Pendiente]</p>
        </div>

      </div>
    </div>
  </section>

  <section class="recursos motion-fadein">
    <div class="contenedor flex-recursos">
      <div class="recursos-texto">
        <h2>Prepárate para el reto</h2>
        <p>No importa si es tu primera vez participando. Ponemos a tu disposición material de estudio, el temario oficial y exámenes de años anteriores para que llegues con la mejor preparación.</p>
      </div>
      <div class="recursos-enlaces">
        <a href="/temario" class="enlace-caja">Ver Temario Oficial &rarr;</a>
        <a href="/material" class="enlace-caja">Exámenes Anteriores &rarr;</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  import { animate, inView } from "motion"
  
  inView(".motion-fadein", (element) => {
    animate(
      element,
      { opacity: [0, 1], y: [20, 0] },
      { duration: 0.6, easing: [0.22, 1, 0.36, 1] }
    )
  })
</script>

<style>
  .contenedor {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  h2 {
    color: var(--azul-uaslp);
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }
  .centrado {
    text-align: center;
  }

  section.hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 4rem 1.5rem;
    min-height: 40vh;
    text-align: center;
  }
  section.hero h1 {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    width: min(100%, 900px);
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .hero-subtitulo {
    font-size: 1.2rem;
    color: var(--negro);
    max-width: 600px;
    margin-bottom: 2rem;
    line-height: 1.5;
  }
  .gradiente-naranja {
    background: linear-gradient(to right, var(--naranja), var(--dorado));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-acciones {
    margin-top: 1rem;
  }

  /* === Info General === */
  section.info-general {
    padding: 4rem 0;
    background-color: #ffffff;
    border-top: 1px solid var(--gris);
    border-bottom: 1px solid var(--gris);
  }
  section.info-general p {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--negro);
  }

  /* === Fechas === */
  section.fechas {
    padding: 5rem 0;
  }
  .grid-fechas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  .tarjeta-fecha {
    background-color: #ffffff;
    border: 1px solid var(--gris);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    position: relative;
  }
  .tarjeta-fecha.destacada {
    border: 2px solid var(--naranja);
    box-shadow: 0 8px 20px rgba(184, 80, 37, 0.15);
    transform: translateY(-10px);
  }
  .etiqueta-alerta {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--naranja);
    color: white;
    padding: 0.2rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    white-space: nowrap;
  }
  .icono {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .tarjeta-fecha h3 {
    color: var(--azul-uaslp);
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }
  .fecha-texto {
    font-size: 1.1rem;
    color: var(--negro);
    font-weight: 600;
  }
  .fecha-texto.principal {
    font-size: 1.4rem;
    color: var(--dorado);
  }
  .hora-texto {
    color: var(--verde);
    font-weight: bold;
    margin-top: 0.3rem;
  }

  /* === Recursos === */
  section.recursos {
    padding: 4rem 0;
    background-color: var(--azul-uaslp);
    color: white;
  }
  section.recursos h2 {
    color: var(--dorado);
  }
  section.recursos p {
    color: var(--negro);
    line-height: 1.6;
  }
  .flex-recursos {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .recursos-texto {
    flex: 1 1 400px;
  }
  .recursos-enlaces {
    flex: 1 1 300px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .enlace-caja {
    display: block;
    background-color: var(--naranja);
    color: var(--crema);
    padding: 1rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    border: 1px solid rgb(115, 52, 0);
    transition: all 0.3s ease;
  }
  .enlace-caja:hover {
    background-color: var(--dorado);
    border-color: var(--dorado);
    transform: translateX(5px);
  }

  @media (max-width: 640px) {
    section.hero {
      padding: 3rem 1rem;
    }
    .tarjeta-fecha.destacada {
      transform: translateY(0);
    }
  }
</style>